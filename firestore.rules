rules_version = '2';

// MovieMatchApp — Firestore security rules
//
// Policy: default deny. Users own their profile + subcollections; other
// authenticated users get narrow, friendship-gated access. Match records
// are readable only to participants.
//
// Known follow-ups (Sprint 2):
//   - Split /users/{uid} into public + private shape so cross-user reads
//     can't see preferences/email.
//   - Wire mutual friend-adding when a match is created so the friendship
//     gate below lines up with the app's match flow.

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny. Every rule below must explicitly open access.
    match /{document=**} {
      allow read, write: if false;
    }

    // --- /users ---
    match /users/{userId} {
      // Owner: full access to own profile.
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Friends-only cross-user read. The requester can read `userId`'s
      // profile ONLY if `userId` has listed the requester in `friends[]`.
      // The previous rule allowed ANY authenticated user to read any
      // profile — that's the leak this replaces.
      allow read: if request.auth != null
                   && request.auth.uid != userId
                   && resource.data.friends is list
                   && request.auth.uid in resource.data.friends;

      // Watchlist subcollection.
      match /watchlist/{itemId} {
        // Owner: full access.
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Friend can read the watchlist of a user that has them as a friend.
        allow get, list: if request.auth != null
                          && userId != request.auth.uid
                          && request.auth.uid in
                             get(/databases/$(database)/documents/users/$(userId)).data.friends;
      }

      // Per-user interaction log. Owner-only.
      match /interactedTitles/{titleId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- /movies, /tvShows (read-only cache) ---
    match /movies/{movieId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /tvShows/{showId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // --- /matches ---
    // Read: only participants. The existing client query uses
    // `where('userIds', 'array-contains', auth.uid)`, which satisfies
    // per-document rule evaluation for both `get` and `list`.
    match /matches/{matchId} {
      allow read: if request.auth != null
                   && request.auth.uid in resource.data.userIds;

      allow create: if request.auth != null &&
                     request.auth.uid in request.resource.data.userIds &&
                     request.resource.data.userIds is list &&
                     request.resource.data.userIds.size() == 2 &&
                     'titleId' in request.resource.data &&
                     'titleType' in request.resource.data &&
                     request.resource.data.titleType is string &&
                     (request.resource.data.titleType == 'movie'
                       || request.resource.data.titleType == 'tv') &&
                     request.resource.data.status == 'new' &&
                     'timestamp' in request.resource.data &&
                     request.resource.data.keys().hasAll(
                       ['userIds', 'titleId', 'titleType', 'timestamp', 'status']) &&
                     request.resource.data.keys().size() == 5;

      allow update: if request.auth != null &&
                     request.auth.uid in resource.data.userIds &&
                     request.resource.data.keys().hasOnly(
                       ['status', 'userIds', 'titleId', 'titleType', 'timestamp']) &&
                     request.resource.data.userIds == resource.data.userIds &&
                     request.resource.data.titleId == resource.data.titleId &&
                     request.resource.data.titleType == resource.data.titleType &&
                     request.resource.data.timestamp == resource.data.timestamp;

      allow delete: if false;
    }
  }
}
