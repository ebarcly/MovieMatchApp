# TMDB (https://www.themoviedb.org/settings/api)
EXPO_PUBLIC_TMDB_API_KEY=

# Firebase Web Config (Project Settings → General → Your apps → Web app)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- Sprint 5b Stream C (LLM surfaces) ---
# Anthropic API key for the client-side AI surfaces (why-you-match +
# rec-copy). Sprint 6 moves inference to Cloud Functions; this is the
# migration seam.
EXPO_PUBLIC_ANTHROPIC_API_KEY=
# Daily LLM cost ceiling in USD. At 80% of this value the app logs a
# warn; at 100% the remaining UTC day degrades to deterministic
# fallbacks. Ratified $25 default (2026-04-18).
EXPO_PUBLIC_MAX_DAILY_LLM_COST_USD=25
