rules_version = '2';

// MovieMatchApp — Firestore security rules
//
// Policy: default deny. Owners own private data; other authenticated users
// get narrow, explicitly-opened access. Sprint 5a introduces two major
// surfaces:
//
//   - /friendships/{id} — a participant-only social graph primitive.
//   - /users/{uid}/public/profile — a public-surface subcollection holding
//     only the fields other users need to render a friend card
//     (displayName, photoURL, tasteLabels, contactHashes). Everything
//     else stays on the private /users/{uid} root doc.
//
// Deployment remains a user task (npx firebase deploy --only firestore:rules)
// — generator verifies the file contents; evaluator confirms deploy via
// manual smoke.

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny. Every rule below must explicitly open access.
    match /{document=**} {
      allow read, write: if false;
    }

    // --- /users (PRIVATE ROOT DOC) ---
    // Owner-only reads + writes on the private doc (email, phone,
    // tasteProfile axes, interactedTitles, genres, streamingServices,
    // settings). No cross-user reads here anymore — cross-user discovery
    // goes through /users/{uid}/public/profile instead.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // --- PUBLIC PROFILE SUBCOLLECTION (Sprint 5a) ---
      // Any authenticated user can READ the public profile (needed for
      // friend-candidate surfaces + match% display in 5b). Only the owner
      // can WRITE.
      match /public/{document=**} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Watchlist subcollection — owner-only in 5a (cross-user queue
      // access moves to /queues/{id} in 5b).
      match /watchlist/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Per-user interaction log. Owner-only.
      match /interactedTitles/{titleId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- /friendships (Sprint 5a) ---
    // Document shape: { participants: [uidA, uidB] (sorted lexicographically),
    //                   status: 'pending' | 'accepted' | 'blocked',
    //                   createdAt, acceptedAt?, initiatedBy }
    //
    // friendshipId = `${min(uidA,uidB)}_${max(uidA,uidB)}` enforces uniqueness
    // via the document ID (one friendship per pair, regardless of argument
    // order).
    match /friendships/{friendshipId} {
      // Participants can read their own friendships.
      allow read: if request.auth != null
                   && request.auth.uid in resource.data.participants;

      // Create: initiator must be one of the participants, document must
      // include both participants + status='pending' + initiatedBy=requester.
      allow create: if request.auth != null
                     && request.auth.uid in request.resource.data.participants
                     && request.resource.data.participants is list
                     && request.resource.data.participants.size() == 2
                     && request.resource.data.status == 'pending'
                     && request.resource.data.initiatedBy == request.auth.uid;

      // Update: only participants; initiatedBy + participants immutable;
      // status can only transition pending -> accepted|blocked.
      allow update: if request.auth != null
                     && request.auth.uid in resource.data.participants
                     && request.resource.data.participants == resource.data.participants
                     && request.resource.data.initiatedBy == resource.data.initiatedBy
                     && (request.resource.data.status == 'accepted'
                         || request.resource.data.status == 'blocked'
                         || request.resource.data.status == 'pending');

      // Delete: only participants (for decline / unfriend).
      allow delete: if request.auth != null
                     && request.auth.uid in resource.data.participants;
    }

    // --- /migrations (Sprint 5a debug log) ---
    // Each migration event is written by the migrating user; no cross-user
    // reads.
    match /migrations/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- /movies, /tvShows (read-only cache) ---
    match /movies/{movieId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /tvShows/{showId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // --- /matches ---
    // Read: only participants. Client query uses
    // `where('userIds', 'array-contains', auth.uid)` which satisfies the
    // per-document rule for both get + list.
    match /matches/{matchId} {
      allow read: if request.auth != null
                   && request.auth.uid in resource.data.userIds;

      allow create: if request.auth != null &&
                     request.auth.uid in request.resource.data.userIds &&
                     request.resource.data.userIds is list &&
                     request.resource.data.userIds.size() == 2 &&
                     'titleId' in request.resource.data &&
                     'titleType' in request.resource.data &&
                     request.resource.data.titleType is string &&
                     (request.resource.data.titleType == 'movie'
                       || request.resource.data.titleType == 'tv') &&
                     request.resource.data.status == 'new' &&
                     'timestamp' in request.resource.data &&
                     request.resource.data.keys().hasAll(
                       ['userIds', 'titleId', 'titleType', 'timestamp', 'status']) &&
                     request.resource.data.keys().size() == 5;

      allow update: if request.auth != null &&
                     request.auth.uid in resource.data.userIds &&
                     request.resource.data.keys().hasOnly(
                       ['status', 'userIds', 'titleId', 'titleType', 'timestamp']) &&
                     request.resource.data.userIds == resource.data.userIds &&
                     request.resource.data.titleId == resource.data.titleId &&
                     request.resource.data.titleType == resource.data.titleType &&
                     request.resource.data.timestamp == resource.data.timestamp;

      allow delete: if false;
    }
  }
}
