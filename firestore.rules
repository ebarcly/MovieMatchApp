rules_version = '2';

// MovieMatchApp — Firestore security rules
//
// Policy: default deny. Owners own private data; other authenticated users
// get narrow, explicitly-opened access. Sprint 5a introduces two major
// surfaces:
//
//   - /friendships/{id} — a participant-only social graph primitive.
//   - /users/{uid}/public/profile — a public-surface subcollection holding
//     only the fields other users need to render a friend card
//     (displayName, photoURL, tasteLabels, contactHashes). Everything
//     else stays on the private /users/{uid} root doc.
//
// Deployment remains a user task (npx firebase deploy --only firestore:rules)
// — generator verifies the file contents; evaluator confirms deploy via
// manual smoke.

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny. Every rule below must explicitly open access.
    match /{document=**} {
      allow read, write: if false;
    }

    // --- /users (PRIVATE ROOT DOC) ---
    // Owner-only reads + writes on the private doc (email, phone,
    // tasteProfile axes, interactedTitles, genres, streamingServices,
    // settings). No cross-user reads here anymore — cross-user discovery
    // goes through /users/{uid}/public/profile instead.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // --- PUBLIC PROFILE SUBCOLLECTION (Sprint 5a) ---
      // Any authenticated user can READ the public profile (needed for
      // friend-candidate surfaces + match% display in 5b). Only the owner
      // can WRITE.
      match /public/{document=**} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Watchlist subcollection — owner-only in 5a (cross-user queue
      // access moves to /queues/{id} in 5b).
      match /watchlist/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Per-user interaction log. Owner-only.
      match /interactedTitles/{titleId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- /friendships (Sprint 5a) ---
    // Document shape: { participants: [uidA, uidB] (sorted lexicographically),
    //                   status: 'pending' | 'accepted' | 'blocked',
    //                   createdAt, acceptedAt?, initiatedBy }
    //
    // friendshipId = `${min(uidA,uidB)}_${max(uidA,uidB)}` enforces uniqueness
    // via the document ID (one friendship per pair, regardless of argument
    // order).
    match /friendships/{friendshipId} {
      // Participants can read their own friendships.
      allow read: if request.auth != null
                   && request.auth.uid in resource.data.participants;

      // Create: initiator must be one of the participants, document must
      // include both participants + status='pending' + initiatedBy=requester.
      allow create: if request.auth != null
                     && request.auth.uid in request.resource.data.participants
                     && request.resource.data.participants is list
                     && request.resource.data.participants.size() == 2
                     && request.resource.data.status == 'pending'
                     && request.resource.data.initiatedBy == request.auth.uid;

      // Update: only participants; initiatedBy + participants immutable;
      // status can only transition pending -> accepted|blocked.
      allow update: if request.auth != null
                     && request.auth.uid in resource.data.participants
                     && request.resource.data.participants == resource.data.participants
                     && request.resource.data.initiatedBy == resource.data.initiatedBy
                     && (request.resource.data.status == 'accepted'
                         || request.resource.data.status == 'blocked'
                         || request.resource.data.status == 'pending');

      // Delete: only participants (for decline / unfriend).
      allow delete: if request.auth != null
                     && request.auth.uid in resource.data.participants;
    }

    // --- /queues (Sprint 5b Stream D) ---
    // Shared watch queue. 2-5 participants co-author an ordered list of
    // titleIds with 1-tap reactions + round-robin "your turn to pick"
    // rotation. Shape:
    //   { participants: string[] (2-5 uids, lex-sorted),
    //     orderedTitleIds: number[],
    //     reactions: { "{titleId}_{uid}": '👍'|'🔥'|'😴'|'⏭️' },
    //     nextPickUid: uid, createdAt, name? }
    //
    // Participants ONLY read/write. Add-title is open to any participant
    // (rule below). Mark-watched requires `nextPickUid == auth.uid`.
    // Activity log lives in /queues/{queueId}/activity.
    match /queues/{queueId} {
      allow read: if request.auth != null
                   && request.auth.uid in resource.data.participants;

      allow create: if request.auth != null
                     && request.auth.uid in request.resource.data.participants
                     && request.resource.data.participants is list
                     && request.resource.data.participants.size() >= 2
                     && request.resource.data.participants.size() <= 5
                     && request.resource.data.orderedTitleIds is list
                     && request.resource.data.nextPickUid is string
                     && request.resource.data.nextPickUid in request.resource.data.participants;

      // Update: participants only; participants list immutable. The
      // mark-watched transition additionally requires that the OLD
      // nextPickUid equals the caller's uid — enforced by checking the
      // transition between resource.data (pre-update) and request.resource.data.
      allow update: if request.auth != null
                     && request.auth.uid in resource.data.participants
                     && request.resource.data.participants == resource.data.participants
                     && (
                       // Add title / react — nextPickUid unchanged.
                       request.resource.data.nextPickUid == resource.data.nextPickUid
                       // OR mark watched — only current picker may rotate.
                       || resource.data.nextPickUid == request.auth.uid
                     );

      allow delete: if false;

      // Activity subcollection — append-only, participant-only.
      match /activity/{activityId} {
        allow read: if request.auth != null
                     && request.auth.uid in get(/databases/$(database)/documents/queues/$(queueId)).data.participants;
        allow create: if request.auth != null
                       && request.auth.uid == request.resource.data.actor
                       && request.auth.uid in get(/databases/$(database)/documents/queues/$(queueId)).data.participants;
        allow update, delete: if false;
      }
    }

    // --- /recs (Sprint 5b Stream B) ---
    // Rec card document — a personalized recommendation sent from one
    // signed-in user (`from`) to a friend (`to`). Shape:
    //   { from: uid, to: uid, titleId: number, note: string (30-280),
    //     createdAt: serverTimestamp, viewedAt?: serverTimestamp }
    //
    // Sender creates. Sender + recipient read. Nobody else. Content is
    // immutable post-create except `viewedAt`, which the recipient stamps
    // once on first open. (`/rec/{recId}` hosting preview is a public
    // render of `from` displayName + note + poster; the Firestore doc
    // itself stays participant-gated — the preview HTML fetches title
    // metadata via TMDB on the client, not via an authenticated rec read.)
    match /recs/{recId} {
      allow read: if request.auth != null
                   && (request.auth.uid == resource.data.from
                       || request.auth.uid == resource.data.to);

      allow create: if request.auth != null
                     && request.auth.uid == request.resource.data.from
                     && request.resource.data.from is string
                     && request.resource.data.to is string
                     && request.resource.data.from != request.resource.data.to
                     && request.resource.data.titleId is number
                     && request.resource.data.note is string
                     && request.resource.data.note.size() >= 30
                     && request.resource.data.note.size() <= 280
                     && 'createdAt' in request.resource.data
                     && request.resource.data.keys().hasOnly(
                         ['from', 'to', 'titleId', 'note', 'createdAt']);

      // Recipient can stamp viewedAt once. Only that field may change.
      allow update: if request.auth != null
                     && request.auth.uid == resource.data.to
                     && request.resource.data.from == resource.data.from
                     && request.resource.data.to == resource.data.to
                     && request.resource.data.titleId == resource.data.titleId
                     && request.resource.data.note == resource.data.note
                     && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if false;
    }

    // --- /aiCache (Sprint 5b Stream C) ---
    // Firestore-backed LLM response cache keyed by SHA-256 hashes. No
    // PII — keys are hashes and payloads are already sanitized text
    // (the `{displayLabel}` placeholder is substituted client-side at
    // render time). Sprint 6 will tighten this to server-only writes
    // when inference moves to Cloud Functions.
    match /aiCache/{hash} {
      allow read, write: if request.auth != null;
    }

    // --- /aiSpend (Sprint 5b Stream C) ---
    // Daily LLM cost tracking, transactionally incremented per call.
    // Keys are yyyy-mm-dd — no PII. Sprint 6 also tightens this.
    match /aiSpend/{dayKey} {
      allow read, write: if request.auth != null;
    }

    // --- /migrations (Sprint 5a debug log) ---
    // Each migration event is written by the migrating user; no cross-user
    // reads.
    match /migrations/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- /movies, /tvShows (read-only cache) ---
    match /movies/{movieId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /tvShows/{showId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // --- /matches ---
    // Read: only participants. Client query uses
    // `where('userIds', 'array-contains', auth.uid)` which satisfies the
    // per-document rule for both get + list.
    match /matches/{matchId} {
      allow read: if request.auth != null
                   && request.auth.uid in resource.data.userIds;

      allow create: if request.auth != null &&
                     request.auth.uid in request.resource.data.userIds &&
                     request.resource.data.userIds is list &&
                     request.resource.data.userIds.size() == 2 &&
                     'titleId' in request.resource.data &&
                     'titleType' in request.resource.data &&
                     request.resource.data.titleType is string &&
                     (request.resource.data.titleType == 'movie'
                       || request.resource.data.titleType == 'tv') &&
                     request.resource.data.status == 'new' &&
                     'timestamp' in request.resource.data &&
                     request.resource.data.keys().hasAll(
                       ['userIds', 'titleId', 'titleType', 'timestamp', 'status']) &&
                     request.resource.data.keys().size() == 5;

      allow update: if request.auth != null &&
                     request.auth.uid in resource.data.userIds &&
                     request.resource.data.keys().hasOnly(
                       ['status', 'userIds', 'titleId', 'titleType', 'timestamp']) &&
                     request.resource.data.userIds == resource.data.userIds &&
                     request.resource.data.titleId == resource.data.titleId &&
                     request.resource.data.titleType == resource.data.titleType &&
                     request.resource.data.timestamp == resource.data.timestamp;

      allow delete: if false;
    }
  }
}
